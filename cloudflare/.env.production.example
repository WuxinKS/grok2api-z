# Cloudflare production vars example
# Use these values as a starting point for Wrangler vars / dashboard vars.

CONTAINER_PORT=8000
CONTAINER_IDLE_TIMEOUT=10m
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
SERVER_WORKERS=1
LOG_LEVEL=INFO
LOG_FILE_ENABLED=false
DATA_DIR=/tmp/data
SERVER_STORAGE_TYPE=redis
SERVER_STORAGE_URL=redis://<user>:<password>@<host>:6379/0
FLARESOLVERR_URL=
CF_REFRESH_INTERVAL=600
CF_TIMEOUT=60
